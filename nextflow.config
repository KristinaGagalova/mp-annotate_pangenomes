// nextflow.config

// Default Singularity configuration
def scratchDir = "/scratch/" + System.getenv('PAWSEY_PROJECT')

singularity {
    enabled = true
    autoMounts = true
    cacheDir = 'singularity_cache'
    runOptions = '--bind ' + scratchDir
}

// Process configuration
process {
    // Default resource allocation
    cpus = 4
    memory = '8 GB'
    time = '4h'
    
    // Specific resource requirements for database setup
    withName: 'FUNANNOTATE_SETUP_DB' {
        cpus = 4
        memory = '32 GB'
        time = '24h'
    }
    
    // Resource requirements for prediction
    withName: 'FUNANNOTATE_PREDICT' {
        cpus = 8
        memory = '32 GB'
        time = '12h'
    }
    
    // Resource requirements for clean step
    withName: 'FUNANNOTATE_CLEAN' {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }
    
    // Resource requirements for annotation
    withName: 'FUNANNOTATE_ANNOTATE' {
        cpus = 8
        memory = '16 GB'
        time = '6h'
    }

}

// Profile configurations
profiles {
    // Setonix Pawsey HPC profile
    setonix {
        // Use the nf-core Setonix configuration
        includeConfig 'https://raw.githubusercontent.com/nf-core/configs/master/conf/pawsey_setonix.config'
        
        // Additional Setonix-specific settings
        process {
            // Set work directory to scratch
            workDir = "${System.getenv('MYSCRATCH')}/nxf_work"
            
            // Setonix-specific resource adjustments
            withName: 'FUNANNOTATE_SETUP_DB' {
                queue = 'work'
                cpus = 4
                memory = '64 GB'
                time = '24h'
                clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
            }
            
            withName: 'FUNANNOTATE_PREDICT' {
                queue = 'work'
                cpus = 16
                memory = '64 GB'
                time = '24h'
                clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
            }
            
            withName: 'FUNANNOTATE_CLEAN' {
                queue = 'work'
                cpus = 8
                memory = '32 GB'
                time = '8h'
                clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
            }
            
            withName: 'FUNANNOTATE_ANNOTATE' {
                queue = 'work'
                cpus = 16
                memory = '32 GB'
                time = '12h'
                clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
            }
   
            withName: 'RNABLOOM_ASSEMBLE' {
                cpus = 24
                memory = '200 GB'
                time = '12h'
                clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
    }
        }
        
        // Executor configuration
        executor {
            name = 'slurm'
            queueSize = 1024
        }
    }
    
    // Singularity profile - enhances Singularity settings
    singularity {
            enabled = true
            autoMounts = true
            runOptions = '--cleanenv'
    }
    
    // Setonix + Singularity optimized settings
    'setonix,singularity' {
        singularity {
            enabled = true
            autoMounts = true
            cacheDir = "${System.getenv('MYSOFTWARE')}/.nextflow_singularity"
            runOptions = '--cleanenv --bind /scratch,/group,/software'
            envWhitelist = 'SINGULARITY_BINDPATH,SINGULARITYENV_LD_LIBRARY_PATH,SINGULARITYENV_LD_PRELOAD'
        }
    }
    
    // Docker profile as alternative
    docker {
        docker {
            enabled = true
            runOptions = '-u $(id -u):$(id -g)'
        }
        
        process {
            executor = 'local'
        }
    }
}

// Pipeline parameters
params {
    transcripts = null
    genomes = null
    database_dir = null
    outdir = "results"
    
    // Funannotate-specific parameters
    buscoseed = 'anidulans'
    species = "Ascomycota"
    buscodb = 'fungi'
    organism = 'fungus'
    ploidy = 1
}

// Execution reports
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
}
